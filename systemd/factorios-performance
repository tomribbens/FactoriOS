#!/bin/bash
# FactoriOS "gamemode" tuning, applied unconditionally because the
# distro only runs Factorio. Adapted from FeralInteractive/gamemode's
# defaults; we skip the parts that need vendor drivers we don't ship
# (nvidia-settings), are laptop-specific in ways a kiosk never sees
# (screensaver inhibition — labwc doesn't blank), or could actively
# hurt if misapplied (CPU pinning, mitigations=off).
#
# Every step is best-effort: missing sysfs paths just mean the host
# doesn't have that knob (AMD-only on a Intel iGPU box, etc.), so we
# log and continue rather than fail the boot.
set -u

apply() {
    local path=$1 value=$2 label=$3
    if [[ -w "$path" ]]; then
        if printf '%s\n' "$value" > "$path" 2>/dev/null; then
            echo "performance: ${label} -> ${value} (${path})"
        else
            echo "performance: ${label} write to ${path} failed" >&2
        fi
    fi
}

# CPU governor: performance on every cpufreq policy. Factorio is
# dominated by a single hot thread; schedutil/powersave underclock
# it during load-time lulls in ways that visibly hurt UPS.
shopt -s nullglob
for gov in /sys/devices/system/cpu/cpufreq/policy*/scaling_governor; do
    apply "${gov}" performance "cpu governor"
done

# ACPI platform profile (laptops + some mini-PCs). Only write when the
# firmware actually advertises 'performance' as a valid choice.
if [[ -f /sys/firmware/acpi/platform_profile_choices ]] \
        && grep -qw performance /sys/firmware/acpi/platform_profile_choices; then
    apply /sys/firmware/acpi/platform_profile performance "platform profile"
fi

# AMD GPU: pin the DPM state at the top performance level. amdgpu only
# exposes this when it actually owns the card; no-op on Intel/Nouveau/
# proprietary nvidia.
for lvl in /sys/class/drm/card*/device/power_dpm_force_performance_level; do
    apply "${lvl}" high "amdgpu dpm level"
done

# Disable kernel split-lock mitigation — otherwise processes issuing
# cross-cacheline atomic ops get either SIGBUS'd or rate-limited via a
# per-cpu sleeping lock, both of which hurt games.
apply /proc/sys/kernel/split_lock_mitigate 0 "split-lock mitigate"

# Never fail the boot for a tuning step.
exit 0
