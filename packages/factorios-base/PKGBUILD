# Maintainer: FactoriOS
#
# Meta-package: pulls in everything an installed FactoriOS system needs and
# drops the systemd unit + the factorios system user.
pkgname=factorios-base
pkgver=0.1.0
pkgrel=1
pkgdesc="FactoriOS system glue: factorios user, systemd unit, kiosk session"
arch=('any')
url="https://example.invalid/factorios"
license=('MIT')
depends=(
    'factorios-greeter'
    'factorios-launcher'
    'labwc'
    'seatd'
    'mesa'
    'vulkan-icd-loader'
    'networkmanager'
)
source=()
install=factorios-base.install

prepare() {
    cp "$startdir/../../systemd/factorios.service"          "$srcdir/factorios.service"
    cp "$startdir/../../systemd/factorios-session"          "$srcdir/factorios-session"
    cp "$startdir/../../systemd/factorios-tmpfiles.conf"    "$srcdir/factorios-tmpfiles.conf"
    cp "$startdir/../../systemd/factorios-sysusers.conf"    "$srcdir/factorios-sysusers.conf"
    cp "$startdir/../../systemd/factorios-pacman.sudoers"   "$srcdir/factorios-pacman.sudoers"
}

package() {
    install -Dm644 "$srcdir/factorios.service" \
        "$pkgdir/usr/lib/systemd/system/factorios.service"
    install -Dm755 "$srcdir/factorios-session" \
        "$pkgdir/usr/bin/factorios-session"
    install -Dm644 "$srcdir/factorios-tmpfiles.conf" \
        "$pkgdir/usr/lib/tmpfiles.d/factorios.conf"
    install -Dm644 "$srcdir/factorios-sysusers.conf" \
        "$pkgdir/usr/lib/sysusers.d/factorios.conf"
    # sudoers files must be mode 440 — sudo refuses to read otherwise.
    install -Dm440 "$srcdir/factorios-pacman.sudoers" \
        "$pkgdir/etc/sudoers.d/factorios-pacman"
}
